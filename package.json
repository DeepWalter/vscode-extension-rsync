{
  "name": "rsync",
  "displayName": "rsync",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "taskDefinitions": [
      {
        "type": "rsync",
        "properties": {}
      }
    ],
    "commands": [
      {
        "command": "rsync.syncCurrentFile",
        "title": "rsync: Sync Current File to Remote"
      },
      {
        "command": "rsync.syncProject",
        "title": "rsync: Sync Entire Project to Remote"
      },
      {
        "command": "rsync.config",
        "title": "rsync: Configure Workspace Settings"
      }
    ],
    "configuration": {
      "title": "rsync",
      "properties": {
        "rsync.remoteHost": {
          "type": "string",
          "default": "",
          "description": "Remote host in rsync format (e.g., user@host)"
        },
        "rsync.remotePath": {
          "type": "string",
          "default": "",
          "description": "Destination path on remote (e.g., /home/user/project/)"
        },
        "rsync.rsyncPath": {
          "type": "string",
          "default": "rsync",
          "description": "Path to the rsync binary"
        },
        "rsync.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".git",
            "node_modules",
            "out",
            ".vscode-test"
          ],
          "description": "Exclusion patterns passed to --exclude"
        },
        "rsync.extraOptions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "-az",
            "--delete"
          ],
          "description": "Extra rsync flags"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}