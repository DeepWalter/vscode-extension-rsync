{
  "name": "rsync",
  "displayName": "Remote Sync",
  "description": "Sync files to a remote host via rsync",
  "private": true,
  "publisher": "deepwalter",
  "license": "MIT",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/DeepWalter/vscode-extension-rsync"
  },
  "bugs": {
    "url": "https://github.com/DeepWalter/vscode-extension-rsync/issues"
  },
  "homepage": "https://github.com/DeepWalter/vscode-extension-rsync#readme",
  "icon": "images/icon.png",
  "keywords": [
    "rsync",
    "sync",
    "remote",
    "deploy",
    "upload"
  ],
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "taskDefinitions": [
      {
        "type": "rsync",
        "properties": {}
      }
    ],
    "commands": [
      {
        "command": "rsync.syncCurrentFile",
        "title": "rsync: Sync Current File to Remote"
      },
      {
        "command": "rsync.syncProject",
        "title": "rsync: Sync Entire Project to Remote"
      },
      {
        "command": "rsync.config",
        "title": "rsync: Configure Workspace Settings"
      }
    ],
    "configuration": {
      "title": "rsync",
      "properties": {
        "rsync.remoteHost": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "markdownDescription": "Remote host in rsync format (e.g., `user@host`)"
        },
        "rsync.remoteName": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "markdownDescription": "Optional display name for the remote host. If set, the status bar shows \"rsync to \\<name\\>\" instead of the raw host."
        },
        "rsync.remotePath": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "markdownDescription": "Destination path on remote (e.g., `/home/user/project/`)"
        },
        "rsync.rsyncPath": {
          "type": "string",
          "default": "rsync",
          "scope": "machine-overridable",
          "markdownDescription": "Path to the `rsync` binary"
        },
        "rsync.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".vscode",
            ".idea",
            ".DS_Store",
            "node_modules",
            ".vscode-test",
            "**/__pycache__/",
            "*.py[co]",
            ".venv",
            "venv",
            ".env",
            ".pytest_cache",
            ".mypy_cache",
            ".ruff_cache",
            ".tox",
            "dist",
            "build",
            "*.egg-info",
            "*.log"
          ],
          "scope": "resource",
          "markdownDescription": "Exclusion patterns passed to `--exclude`"
        },
        "rsync.extraOptions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "-az",
            "--delete"
          ],
          "scope": "resource",
          "markdownDescription": "Extra rsync flags (e.g., `-az`, `--delete`)"
        },
        "rsync.syncOnSave": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "markdownDescription": "Automatically sync the current file to the remote when it is saved"
        },
        "rsync.syncOnSaveDelay": {
          "type": "number",
          "default": 500,
          "minimum": 0,
          "scope": "resource",
          "markdownDescription": "Delay in milliseconds before syncing on save. The timer resets on each save, so rapid saves (e.g., from formatters or other extensions) will only trigger one sync. Set to `0` for immediate sync."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}