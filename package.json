{
  "name": "rsync",
  "displayName": "Remote Sync",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "taskDefinitions": [
      {
        "type": "rsync",
        "properties": {}
      }
    ],
    "commands": [
      {
        "command": "rsync.syncCurrentFile",
        "title": "rsync: Sync Current File to Remote"
      },
      {
        "command": "rsync.syncProject",
        "title": "rsync: Sync Entire Project to Remote"
      },
      {
        "command": "rsync.config",
        "title": "rsync: Configure Workspace Settings"
      }
    ],
    "configuration": {
      "title": "rsync",
      "properties": {
        "rsync.remoteHost": {
          "type": "string",
          "default": "",
          "description": "Remote host in rsync format (e.g., user@host)"
        },
        "rsync.remoteName": {
          "type": "string",
          "default": "",
          "description": "Optional display name for the remote host. If set, the status bar shows \"rsync to <name>\" instead of the raw host."
        },
        "rsync.remotePath": {
          "type": "string",
          "default": "",
          "description": "Destination path on remote (e.g., /home/user/project/)"
        },
        "rsync.rsyncPath": {
          "type": "string",
          "default": "rsync",
          "description": "Path to the rsync binary"
        },
        "rsync.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".vscode",
            ".idea",
            ".DS_Store",
            "node_modules",
            ".vscode-test",
            "**/__pycache__/",
            "*.py[co]",
            ".venv",
            "venv",
            ".env",
            ".pytest_cache",
            ".mypy_cache",
            ".ruff_cache",
            ".tox",
            "dist",
            "build",
            "*.egg-info",
            "*.log"
          ],
          "description": "Exclusion patterns passed to --exclude"
        },
        "rsync.extraOptions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "-az",
            "--delete"
          ],
          "description": "Extra rsync flags"
        },
        "rsync.syncOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically sync the current file to the remote when it is saved"
        },
        "rsync.syncOnSaveDelay": {
          "type": "number",
          "default": 500,
          "minimum": 0,
          "description": "Delay in milliseconds before syncing on save. The timer resets on each save, so rapid saves (e.g., from formatters or other extensions) will only trigger one sync. Set to 0 for immediate sync."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}